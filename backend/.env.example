# Optional: silence [umbrella:dev] logs locally (default: on unless NODE_ENV=production)
# DEV_LOGGING=0

# Database
DATABASE_URL=

# Auth session (HS256 JWT returned to the frontend after login)
JWT_SECRET=

# Frontend origin for CORS + redirects after Google OAuth
# Next.js dev default is often 3001; API is often 3000
FRONTEND_URL=http://localhost:3001

# Google OAuth — redirect must hit THIS API, not Next.js
# Register the same URI in Google Cloud Console → OAuth client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Gmail push notifications (users/me/watch) — full Pub/Sub topic resource name
# Example: projects/my-gcp-project/topics/gmail-updates
# Grant publish to gmail-api-push@system.gserviceaccount.com on this topic.
GMAIL_PUBSUB_TOPIC=

# Optional; comma-separated Gmail label IDs (default: INBOX)
# GMAIL_WATCH_LABEL_IDS=INBOX
